---
import { Image } from 'astro:assets';
import heroImage from '../assets/hero-image.png';
import { useTranslations } from '../i18n/utils';

const t = useTranslations(Astro.currentLocale).hero;
---

<section
  id="hero"
  class="text-secondary relative overflow-hidden grid gap-20 mmd:grid-cols-2 max-w-[1320px] mx-auto w-full pt-10 mmd:pt-0 px-4"
>
  <!-- Subtle dot pattern background -->
  <div class="hero-dots absolute inset-0 -z-10 opacity-[0.03] dark:opacity-[0.05]"></div>

  <div class="grid gap-2 mmd:content-center">
    <h1>
      <span class="block text-5xl font-bold dark:text-white">
        <span class="hero-word" style="--word-index: 0;">{t.words[0]}</span>
        <span class="hero-word" style="--word-index: 1;">{t.words[1]}</span>
      </span>
      <span class="text-primary text-lg font-semibold">
        <span class="hero-word" style="--word-index: 2;">{t.words[2]}</span>
        <span class="hero-word" style="--word-index: 3;">{t.words[3]}</span>
      </span>
    </h1>
    <h2 class="font-semibold dark:text-white hero-fade" style="--fade-delay: 600ms;">
      <span class="text-slate-500">{t.subtitlePre}</span> {t.subtitlePost}
    </h2>
    <p class="max-w-[600px] text-sm text-balance text-slate-400 hero-fade" style="--fade-delay: 800ms;">
      {t.description}
    </p>
    <div class="flex gap-2 mt-4 hero-fade" style="--fade-delay: 1000ms;">
      <a
        href="#contact"
        class="btn-primary bg-primary hover:bg-primary/90 transition-all hover:shadow-md px-6 rounded-full text-white text-sm py-2 font-semibold"
      >
        {t.btnPrimary}
      </a>
      <a
        href="#about"
        class="btn-secondary bg-secondary hover:bg-secondary/80 transition-all hover:shadow-md px-6 rounded-full text-white text-sm py-2 font-semibold dark:bg-white dark:text-primary"
      >
        {t.btnSecondary}
      </a>
    </div>
  </div>
  <div class="hero-fade relative" style="--fade-delay: 500ms;">
    <!-- Gradient mesh blobs (estilo Stripe) -->
    <div id="hero-parallax-circle" class="absolute inset-0 -z-0 will-change-transform">
      <div class="mesh-blob mesh-blob-1"></div>
      <div class="mesh-blob mesh-blob-2"></div>
      <div class="mesh-blob mesh-blob-3"></div>
      <div class="mesh-blob mesh-blob-4"></div>
    </div>
    <Image id="hero-image" class="hero-image relative z-10 block mx-auto" src={heroImage} alt={t.imageAlt} format="webp" quality={80} />
    <!-- Fade-out gradient bottom -->
    <div class="hero-bottom-fade"></div>
  </div>
  <!-- Fade-out gradient right (at section level to cover overflow) -->
  <div class="hero-right-fade"></div>
</section>

<style>
  /* Dot pattern */
  .hero-dots {
    background-image: radial-gradient(circle, rgb(74, 108, 247) 1px, transparent 1px);
    background-size: 30px 30px;
  }

  /* Word-by-word animation */
  .hero-word {
    display: inline-block;
    opacity: 0;
    transform: translateY(20px);
    animation: heroWordIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--word-index) * 120ms + 100ms);
  }

  /* Fade-in for subtitle, description, buttons, image */
  .hero-fade {
    opacity: 0;
    transform: translateY(25px);
    animation: heroFadeIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--fade-delay);
  }

  @keyframes heroWordIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes heroFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Bottom fade-out gradient */
  .hero-bottom-fade {
    position: absolute;
    bottom: 0;
    left: -10%;
    right: -10%;
    height: 45%;
    background: linear-gradient(to top, white 5%, transparent 100%);
    z-index: 20;
    pointer-events: none;
  }

  :global(.dark) .hero-bottom-fade {
    background: linear-gradient(to top, #050816 5%, transparent 100%);
  }

  .hero-right-fade {
    position: absolute;
    top: 0;
    right: -1px;
    bottom: 0;
    width: 12%;
    background: linear-gradient(to left, white 15%, transparent 100%);
    z-index: 30;
    pointer-events: none;
  }

  :global(.dark) .hero-right-fade {
    background: linear-gradient(to left, #050816 15%, transparent 100%);
  }

  /* Gradient mesh blobs */
  .mesh-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.4;
    will-change: transform;
  }

  :global(.dark) .mesh-blob {
    opacity: 0.5;
  }

  .mesh-blob-1 {
    width: 350px;
    height: 350px;
    background: rgb(74, 108, 247);
    bottom: -10%;
    right: -5%;
    animation: meshFloat1 35s ease-in-out infinite;
  }

  .mesh-blob-2 {
    width: 280px;
    height: 280px;
    background: rgb(120, 80, 220);
    bottom: 10%;
    right: 15%;
    animation: meshFloat2 40s ease-in-out infinite;
  }

  .mesh-blob-3 {
    width: 220px;
    height: 220px;
    background: rgb(30, 59, 179);
    bottom: -5%;
    right: 30%;
    animation: meshFloat3 30s ease-in-out infinite;
  }

  .mesh-blob-4 {
    width: 180px;
    height: 180px;
    background: rgb(99, 102, 241);
    bottom: 25%;
    right: 0%;
    animation: meshFloat4 45s ease-in-out infinite;
  }

  @keyframes meshFloat1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(30px, -40px) scale(1.05); }
    50% { transform: translate(-20px, -60px) scale(0.95); }
    75% { transform: translate(40px, -20px) scale(1.08); }
  }

  @keyframes meshFloat2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(-40px, 30px) scale(1.1); }
    50% { transform: translate(30px, 50px) scale(0.9); }
    75% { transform: translate(-20px, -30px) scale(1.05); }
  }

  @keyframes meshFloat3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(50px, -30px) scale(1.08); }
    66% { transform: translate(-30px, 40px) scale(0.92); }
  }

  @keyframes meshFloat4 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    20% { transform: translate(-25px, -45px) scale(1.06); }
    40% { transform: translate(35px, -15px) scale(0.94); }
    60% { transform: translate(-15px, 35px) scale(1.1); }
    80% { transform: translate(20px, 20px) scale(0.96); }
  }

  .hero-image {
    will-change: transform, opacity;
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-word,
    .hero-fade {
      opacity: 1;
      transform: none;
      animation: none;
    }

    .mesh-blob {
      animation: none;
    }

  }
</style>

<script>
  function initHeroScroll() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const img = document.getElementById('hero-image') as HTMLElement | null;
    const hero = document.getElementById('hero');
    if (!img || !hero) return;

    let target = 0;
    let current = 0;
    let rafId: number | null = null;
    let running = false;

    const LERP = 0.08;
    const MAX_TRANSLATE = 115;
    const MAX_FADE = 0.9;

    function ease(t: number) {
      return t * t * (3 - 2 * t);
    }

    function tick() {
      current += (target - current) * LERP;
      const eased = ease(Math.max(0, Math.min(1, current)));
      img!.style.transform = `translate3d(${eased * MAX_TRANSLATE}%, 0, 0)`;
      img!.style.opacity = `${1 - eased * MAX_FADE}`;

      if (Math.abs(target - current) > 0.0005) {
        rafId = requestAnimationFrame(tick);
      } else {
        current = target;
        running = false;
        rafId = null;
      }
    }

    function computeTarget() {
      const rect = hero!.getBoundingClientRect();
      target = Math.max(0, Math.min(1, -rect.top / rect.height));
      if (!running) {
        running = true;
        rafId = requestAnimationFrame(tick);
      }
    }

    window.addEventListener('scroll', computeTarget, { passive: true });
    window.addEventListener('resize', computeTarget, { passive: true });
    computeTarget();
  }

  document.addEventListener('DOMContentLoaded', initHeroScroll);
  document.addEventListener('astro:page-load', initHeroScroll);
</script>

