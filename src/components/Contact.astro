---
import Section from "../components/Section.astro";
---

<Section id="contact" styles="grid gap-2 text-center relative">
  <!-- Decorative blobs -->
  <div class="absolute -right-32 top-0 w-72 h-72 bg-primary/5 dark:bg-primary/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute -left-24 bottom-10 w-56 h-56 bg-primary/5 dark:bg-primary/8 rounded-full blur-3xl pointer-events-none"></div>
  <h4 data-reveal class="text-primary text-lg font-semibold">Contacta con nosotros</h4>
  <h3 data-reveal class="text-4xl font-bold dark:text-white" style="transition-delay: 100ms;">
    ¿Tienes algún proyecto en mente?
  </h3>
  <p data-reveal class="text-balance max-w-[500px] mx-auto text-slate-500" style="transition-delay: 200ms;">
    En CodeVista, transformamos tus ideas en realidad digital. Cuéntanos tu
    visión y trabajaremos juntos para hacerla posible.
  </p>

  <div data-reveal style="transition-delay: 300ms;" class="grid grid-cols-1 mmd:grid-cols-[1fr_1.5fr] gap-10 max-w-[900px] mx-auto w-full mt-10">
    <!-- Contact info -->
    <div class="flex flex-col gap-6 text-left">
      <h4 class="text-xl font-bold dark:text-white">Información de contacto</h4>
      <div class="flex items-start gap-3">
        <div class="bg-primary/10 dark:bg-primary/20 p-2.5 rounded-lg text-primary flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z"/><path d="M3 7l9 6l9 -6"/></svg>
        </div>
        <div>
          <p class="text-xs text-slate-400">Correo</p>
          <p class="text-sm font-medium dark:text-white">contacto@codevista.com</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <div class="bg-primary/10 dark:bg-primary/20 p-2.5 rounded-lg text-primary flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 4h4l2 5l-2.5 1.5a11 11 0 0 0 5 5l1.5 -2.5l5 2v4a2 2 0 0 1 -2 2a16 16 0 0 1 -15 -15a2 2 0 0 1 2 -2"/></svg>
        </div>
        <div>
          <p class="text-xs text-slate-400">Teléfono</p>
          <p class="text-sm font-medium dark:text-white">+57 318 428 1039</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <div class="bg-primary/10 dark:bg-primary/20 p-2.5 rounded-lg text-primary flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11a3 3 0 1 0 6 0a3 3 0 0 0 -6 0"/><path d="M17.657 16.657l-4.243 4.243a2 2 0 0 1 -2.827 0l-4.244 -4.243a8 8 0 1 1 11.314 0z"/></svg>
        </div>
        <div>
          <p class="text-xs text-slate-400">Ubicación</p>
          <p class="text-sm font-medium dark:text-white">Colombia</p>
        </div>
      </div>
    </div>

    <!-- Form -->
    <form class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <label
        for="name"
        class="contact-field relative block overflow-hidden border-b border-gray-200 pt-3 focus-within:border-primary bg-slate-300/10 transition-all duration-300"
      >
        <div class="absolute left-0 top-1/2 -translate-y-1/2 text-slate-400 peer-focus:text-primary transition-colors pl-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 7a4 4 0 1 0 8 0a4 4 0 0 0 -8 0"/><path d="M6 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2"/></svg>
        </div>
        <input
          type="text"
          id="name"
          placeholder="Ingrese su nombre"
          class="peer h-8 w-full border-none bg-transparent pl-6 p-0 placeholder-transparent focus:border-transparent focus:outline-none focus:ring-0 sm:text-sm dark:text-white"
        />
        <span
          class="absolute start-6 top-2 -translate-y-1/2 text-xs text-gray-900 transition-all peer-placeholder-shown:top-1/2 peer-placeholder-shown:text-sm peer-focus:top-2 peer-focus:text-xs peer-focus:text-primary dark:text-white"
        >
          Nombre
        </span>
      </label>
      <label
        for="company"
        class="contact-field relative block overflow-hidden border-b border-gray-200 pt-3 focus-within:border-primary bg-slate-300/10 transition-all duration-300"
      >
        <div class="absolute left-0 top-1/2 -translate-y-1/2 text-slate-400 pl-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l18 0"/><path d="M9 8l1 0"/><path d="M9 12l1 0"/><path d="M9 16l1 0"/><path d="M14 8l1 0"/><path d="M14 12l1 0"/><path d="M14 16l1 0"/><path d="M5 21v-16a2 2 0 0 1 2 -2h10a2 2 0 0 1 2 2v16"/></svg>
        </div>
        <input
          type="text"
          id="company"
          placeholder="Compañia (Opcional)"
          class="peer h-8 w-full border-none bg-transparent pl-6 p-0 placeholder-transparent focus:border-transparent focus:outline-none focus:ring-0 sm:text-sm dark:text-white"
        />
        <span
          class="absolute start-6 top-2 -translate-y-1/2 text-xs text-gray-900 transition-all peer-placeholder-shown:top-1/2 peer-placeholder-shown:text-sm peer-focus:top-2 peer-focus:text-xs peer-focus:text-primary dark:text-white"
        >
          Compañia (Opcional)
        </span>
      </label>
      <label
        for="email"
        class="contact-field relative block overflow-hidden border-b border-gray-200 pt-3 focus-within:border-primary bg-slate-300/10 transition-all duration-300"
      >
        <div class="absolute left-0 top-1/2 -translate-y-1/2 text-slate-400 pl-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z"/><path d="M3 7l9 6l9 -6"/></svg>
        </div>
        <input
          type="email"
          id="email"
          placeholder="Email"
          class="peer h-8 w-full border-none bg-transparent pl-6 p-0 placeholder-transparent focus:border-transparent focus:outline-none focus:ring-0 sm:text-sm dark:text-white"
        />
        <span
          class="absolute start-6 top-2 -translate-y-1/2 text-xs text-gray-900 transition-all peer-placeholder-shown:top-1/2 peer-placeholder-shown:text-sm peer-focus:top-2 peer-focus:text-xs peer-focus:text-primary dark:text-white"
        >
          Correo
        </span>
      </label>
      <label
        for="phone"
        class="contact-field relative block overflow-hidden border-b border-gray-200 pt-3 focus-within:border-primary bg-slate-300/10 transition-all duration-300"
      >
        <div class="absolute left-0 top-1/2 -translate-y-1/2 text-slate-400 pl-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 4h4l2 5l-2.5 1.5a11 11 0 0 0 5 5l1.5 -2.5l5 2v4a2 2 0 0 1 -2 2a16 16 0 0 1 -15 -15a2 2 0 0 1 2 -2"/></svg>
        </div>
        <input
          type="tel"
          id="phone"
          placeholder="Telefono"
          class="peer h-8 w-full border-none bg-transparent pl-6 p-0 placeholder-transparent focus:border-transparent focus:outline-none focus:ring-0 sm:text-sm dark:text-white"
        />
        <span
          class="absolute start-6 top-2 -translate-y-1/2 text-xs text-gray-900 transition-all peer-placeholder-shown:top-1/2 peer-placeholder-shown:text-sm peer-focus:top-2 peer-focus:text-xs peer-focus:text-primary dark:text-white"
        >
          Número de teléfono
        </span>
      </label>
      <label
        for="project-description"
        class="contact-field relative block overflow-hidden border-b border-gray-200 pt-3 focus-within:border-primary bg-slate-300/10 sm:col-span-2 transition-all duration-300"
      >
        <div class="absolute left-0 top-4 text-slate-400 pl-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 3v4a1 1 0 0 0 1 1h4"/><path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z"/><path d="M9 9l1 0"/><path d="M9 13l6 0"/><path d="M9 17l6 0"/></svg>
        </div>
        <textarea
          id="project-description"
          placeholder="Proyecto"
          class="peer h-20 w-full border-none bg-transparent pl-6 p-0 placeholder-transparent focus:border-transparent focus:outline-none focus:ring-0 sm:text-sm resize-none dark:text-white"
        ></textarea>
        <span
          class="absolute start-6 top-2 -translate-y-1/2 text-xs text-gray-900 transition-all peer-placeholder-shown:text-sm peer-focus:top-2 peer-focus:text-xs peer-placeholder-shown:top-4 peer-focus:text-primary dark:text-white"
        >
          Cuéntanos acerca del proyecto
        </span>
      </label>

      <button
        class="btn-primary bg-primary hover:bg-primary/90 transition-all hover:shadow-md px-6 rounded-full text-white text-sm py-2.5 font-semibold sm:col-span-2 max-w-max mx-auto"
      >
        Contactar
      </button>
    </form>
  </div>
</Section>
