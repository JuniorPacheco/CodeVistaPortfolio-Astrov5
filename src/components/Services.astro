---
import { Icon } from "astro-icon/components";
import Section from "./Section.astro";

const services = [
  {
    icon: "brand-codesandbox",
    title: "Desarrollo Web a Medida",
    description:
      "Construimos sitios web y aplicaciones desde cero, adaptados a las necesidades específicas de tu negocio. Código limpio, rendimiento óptimo y escalabilidad garantizada.",
  },
  {
    icon: "brand-visual-studio",
    title: "Diseño Visual",
    description:
      "Destaca tu marca y conecta con tu audiencia de manera memorable con nuestra experiencia en diseño web.",
  },
  {
    icon: "user-search",
    title: "Investigación de Usuarios",
    description:
      "Analizamos el comportamiento y preferencias de tu público para mejorar la usabilidad y aumentar la conversión.",
  },
  {
    icon: "users",
    title: "Experiencia de Usuario",
    description:
      "Garantizamos la excelencia de tu sitio con pruebas exhaustivas para una experiencia óptima del usuario.",
  },
  {
    icon: "device-mobile",
    title: "Diseño Responsivo",
    description:
      "Tu sitio se verá perfecto en cualquier dispositivo. Diseñamos pensando en móvil, tablet y escritorio.",
  },
];
---

<Section id="services" styles="grid gap-2 text-center relative">
  <!-- Decorative blobs -->
  <div class="absolute -right-40 -top-20 w-80 h-80 bg-primary/5 dark:bg-primary/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute -left-32 bottom-0 w-64 h-64 bg-primary/5 dark:bg-primary/10 rounded-full blur-3xl pointer-events-none"></div>
  <h4 data-reveal class="text-primary text-lg font-semibold">¿Qué ofrecemos?</h4>
  <h3 data-split-text class="text-5xl font-bold text-gradient">Nuestros servicios</h3>
  <p data-reveal class="text-balance max-w-[500px] mx-auto text-slate-500" style="transition-delay: 200ms;">
    CodeVista potencia tu presencia en línea con soluciones web personalizadas.
    Desde diseño creativo hasta desarrollo avanzado, hacemos realidad tus
    proyectos digitales. ¡Destácate en la web con nosotros!
  </p>
  <div
    data-reveal-stagger
    class="bento-grid mt-12"
  >
    {
      services.map(({ icon, title, description }, index) => (
        <div
          data-reveal
          data-spotlight
          class:list={[
            "service-card grid gap-2 p-6 py-8 rounded-xl shadow-lg dark:shadow-primary/40 hover:bg-primary hover:-translate-y-2 hover:shadow-xl hover:shadow-primary/25 transition-all duration-300 group relative overflow-hidden",
            index === 0 ? "bento-featured items-start text-left" : "items-center text-center",
          ]}
        >
          <div class="service-card-line"></div>
          <div class:list={[
            "max-w-max bg-primary p-3 rounded-full text-white group-hover:bg-white group-hover:text-primary transition-all duration-300 relative z-10 group-hover:rotate-6",
            index === 0 ? "" : "mx-auto",
          ]}>
            <Icon name={icon} size={index === 0 ? 40 : 35} />
          </div>
          <h5 class:list={[
            "font-bold dark:text-white group-hover:text-white transition-colors relative z-10",
            index === 0 ? "text-xl" : "text-lg",
          ]}>
            {title}
          </h5>
          <p class:list={[
            "text-slate-500 group-hover:text-white transition-colors relative z-10 dark:text-white",
            index === 0 ? "text-sm max-w-md" : "text-sm",
          ]}>
            {description}
          </p>
          <Icon
            class="absolute bottom-0 left-0 text-transparent group-hover:text-white transition-colors"
            name="points"
            size={35}
          />
          <div class="size-28 absolute bg-transparent group-hover:bg-white transition-colors right-0 top-0 rounded-full translate-x-1/2 -translate-y-1/2 opacity-10" />
          <div class="size-48 absolute bg-transparent group-hover:bg-white transition-colors right-0 top-0 rounded-full translate-x-1/4 -translate-y-1/2 opacity-5" />
        </div>
      ))
    }
  </div>
</Section>

<style>
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .bento-featured {
      grid-column: span 2;
    }
  }

  @media (min-width: 1024px) {
    .bento-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .bento-featured {
      grid-column: span 2;
      grid-row: span 1;
    }
  }

  .service-card-line {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 3px;
    background: rgb(74, 108, 247);
    border-radius: 0 0 4px 4px;
    transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .bento-featured .service-card-line {
    left: 0;
    transform: none;
  }

  .service-card:hover .service-card-line {
    width: 100%;
    background: white;
  }
</style>
