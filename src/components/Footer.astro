---
import Section from "../components/Section.astro";
import { Icon } from "astro-icon/components";
import { Image } from 'astro:assets';
import logoDark from '../assets/logo-dark.png';
import { useTranslations } from "../i18n/utils";
import { CONTACT, SOCIAL_LINKS } from '../constants/contact';

const t = useTranslations(Astro.currentLocale).footer;
const quickLinks = t.links.map(({ label, hash }) => ({ label, href: `#${hash}` }));

const socialLinks = SOCIAL_LINKS;
---

<Section
  containerStyle="bg-secondary relative"
  styles="text-slate-400"
  separation="none"
>
  <footer>
    <Icon
      class="absolute left-0 bottom-0 text-primary/10"
      name="arc"
      size={100}
    />
    <div
      class="mx-auto max-w-screen-xl px-4 py-16 sm:px-6 lg:px-8"
    >
      <div data-reveal class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
        <!-- Logo & description -->
        <div class="flex flex-col gap-4">
          <Image class="max-w-[155px]" src={logoDark} alt="CodeVista" format="webp" quality={80} loading="lazy" decoding="async" />
          <p class="text-sm text-slate-400 max-w-[280px]">
            {t.description}
          </p>
        </div>

        <!-- Quick links -->
        <div>
          <h5 class="text-white font-semibold mb-4">{t.linksTitle}</h5>
          <ul class="grid gap-2">
            {quickLinks.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="text-slate-400 text-sm hover:text-primary transition-colors"
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Contact info & social -->
        <div>
          <h5 class="text-white font-semibold mb-4">{t.contactTitle}</h5>
          <ul class="grid gap-2 text-sm">
            <li class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z"/><path d="M3 7l9 6l9 -6"/></svg>
              {CONTACT.email}
            </li>
            <li class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M5 4h4l2 5l-2.5 1.5a11 11 0 0 0 5 5l1.5 -2.5l5 2v4a2 2 0 0 1 -2 2a16 16 0 0 1 -15 -15a2 2 0 0 1 2 -2"/></svg>
              {CONTACT.phone}
            </li>
          </ul>
          <ul class="flex gap-3 mt-5">
            {socialLinks.map(({ label, href, icon, brandColor }) => (
              <li>
                <a
                  href={href}
                  rel="noreferrer"
                  target="_blank"
                  class="social-icon-footer text-slate-500 transition-all duration-300 hover:scale-110"
                  style={`--brand-color: ${brandColor};`}
                >
                  <span class="sr-only">{label}</span>
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={icon} />
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Divider + copyright + scroll to top -->
      <div class="border-t border-white/10 mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-xs text-slate-400">
          {t.copyright}
        </p>
        <a
          href="#hero"
          class="scroll-top-btn group flex items-center gap-2 text-xs text-slate-400 hover:text-primary transition-colors"
        >
          {t.backToTop}
          <span class="border border-slate-500 group-hover:border-primary rounded-full p-1.5 transition-all group-hover:-translate-y-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M18 11l-6 -6l-6 6"/></svg>
          </span>
        </a>
      </div>
    </div>
  </footer>
</Section>

<style>
  .social-icon-footer:hover {
    color: var(--brand-color);
    filter: drop-shadow(0 0 8px color-mix(in srgb, var(--brand-color) 40%, transparent));
  }
</style>
