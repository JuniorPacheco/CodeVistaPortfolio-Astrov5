---
import SliderImages from "./SliderImages";
import Section from "./Section.astro";

const logos = [
  {
    src: "/company-logos/constructor-logo.png",
    name: "Constructor",
  },
  {
    src: "/company-logos/gama-car-logo.png",
    name: "Gama rent cars",
  },
  {
    src: "/company-logos/smart-start-logo.png",
    name: "Smart Start",
  },
  {
    src: "/company-logos/constructor-logo.png",
    name: "Constructor 2",
  },
  {
    src: "/company-logos/gama-car-logo.png",
    name: "Gama rent cars 2",
  },
  {
    src: "/company-logos/smart-start-logo.png",
    name: "Smart Start 2",
  },
];
---

<Section styles="relative overflow-hidden text-center" separation="none">
  <h4 data-reveal class="text-primary text-lg font-semibold">¿Con quien trabajamos?</h4>
  <h3 data-reveal class="text-5xl font-bold text-gradient" style="transition-delay: 100ms;">Nuestros clientes</h3>
  <div data-reveal style="transition-delay: 200ms;">
    <SliderImages images={logos} client:load />
  </div>
</Section>
