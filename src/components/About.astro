---
import Section from "./Section.astro";
import { useTranslations } from "../i18n/utils";
import { SOCIAL_LINKS } from '../constants/contact';

const t = useTranslations(Astro.currentLocale).about;
---

<Section
  id="about"
  styles="text-secondary relative overflow-hidden grid gap-20 mmd:grid-cols-2"
>
  <div class="grid gap-2">
    <h3 data-reveal class="text-lg font-bold text-primary uppercase">{t.tag}</h3>
    <h4 data-reveal class="grid gap-2 text-3xl font-bold dark:text-white" style="transition-delay: 100ms;">
      <span>{t.titleLine1}</span>
      <span>{t.titleLine2}</span>
    </h4>
    <p data-reveal class="text-slate-400" style="transition-delay: 200ms;">
      {t.description}
    </p>
  </div>
  <div>
    <h4 data-reveal class="text-3xl font-bold dark:text-white">{t.connectTitle}</h4>
    <p data-reveal class="my-2 text-slate-500" style="transition-delay: 100ms;">
      {t.connectDescription}
    </p>
    <ul data-reveal class="flex gap-3 py-2" style="transition-delay: 200ms;">
      {SOCIAL_LINKS.map(({ label, href, brandColor, darkBrandColor, icon }) => (
        <li>
          <a
            class="social-icon-about border rounded-full p-2.5 grid place-content-center transition-all duration-300 text-slate-400 dark:text-slate-500 dark:border-slate-700 hover:border-transparent hover:scale-110"
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            style={`--brand-color: ${brandColor}; --brand-color-dark: ${darkBrandColor || brandColor};`}
          >
            <span class="sr-only">{label}</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" set:html={icon} />
          </a>
        </li>
      ))}
    </ul>
  </div>
</Section>

<style>
  .social-icon-about:hover {
    color: var(--brand-color);
    border-color: var(--brand-color);
    box-shadow: 0 0 16px color-mix(in srgb, var(--brand-color) 30%, transparent);
  }

  :global(.dark) .social-icon-about:hover {
    color: var(--brand-color-dark);
    border-color: var(--brand-color-dark);
    box-shadow: 0 0 16px color-mix(in srgb, var(--brand-color-dark) 30%, transparent);
  }
</style>
